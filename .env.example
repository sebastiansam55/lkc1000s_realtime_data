# ==============================================================================
# Home Assistant REST API Configuration (Option 1 - Creates Separate Entities)
# ==============================================================================
# Replace with your Home Assistant server URL and port (usually 8123)
HA_URL=http://homeassistant.local:8123

# Your Home Assistant Long-Lived Access Token.
# Create this in HA under: Profile -> Long-Lived Access Tokens -> Create Token.
HA_TOKEN=your_long_lived_access_token_here


# ==============================================================================
# Home Assistant MQTT Discovery Configuration (Option 2 - Creates One Device)
# ==============================================================================
# The IP address or hostname of your MQTT Broker (e.g. Mosquitto)
MQTT_HOST=192.168.1.100

# The port of your MQTT Broker (default is 1883)
MQTT_PORT=1883

# Credentials for your MQTT Broker (leave blank if not required)
MQTT_USER=mqtt_user
MQTT_PASSWORD=mqtt_password

# Home Assistant Discovery Prefix (default is 'homeassistant')
MQTT_TOPIC_PREFIX=homeassistant
